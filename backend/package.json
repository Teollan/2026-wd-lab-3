  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && tsc && tsc-alias",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "dev": "prisma generate && tsc && tsc-alias && node --env-file-if-exists=.env dist/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:prepare": "prisma migrate dev --create-only",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@prisma/adapter-pg": "^7.8.0",
